# =============================================================================
# TôNaIA — CONFIGURAÇÃO COMPLETA
# =============================================================================
# Copie este arquivo como .env e preencha com seus valores.
# As unicas chaves OBRIGATORIAS para cada funcionalidade estao marcadas.
# =============================================================================

# ─── GOOGLE MAPS PROSPECTOR ─────────────────────────────────────────────────
# OBRIGATORIO para o Prospector (buscar leads no Google Maps)
# Crie em: https://console.cloud.google.com/ → APIs → Places API (New)
GOOGLE_MAPS_API_KEY=sua_chave_aqui

# ─── WHATSAPP API ───────────────────────────────────────────────────────────
# Porta onde o servico Node.js do WhatsApp vai rodar (padrao: 3001)
WHATSAPP_PORT=3001
# URL do servico WhatsApp (so alterar se rodar em outra maquina)
WHATSAPP_API_URL=http://localhost:3001

# ─── FLASK SERVER ───────────────────────────────────────────────────────────
# Porta do servidor Flask (padrao: 5000)
FLASK_PORT=5000
# Host (0.0.0.0 para acessar de outros dispositivos na rede)
FLASK_HOST=0.0.0.0

# ─── MONITORAMENTO ──────────────────────────────────────────────────────────
# Intervalo entre ciclos de auditoria em horas (padrao: 168 = 1 semana)
MONITOR_INTERVALO_HORAS=168

# ─── BACKUP ─────────────────────────────────────────────────────────────────
# Caminho para sincronizar backups (opcional)
# Exemplo: D:\Google Drive\TonaIA\backups
BACKUP_DESTINO=
# Habilitar backup automatico apos cada auditoria (true/false)
BACKUP_AUTO=true
